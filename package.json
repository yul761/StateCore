{
  "name": "statecore",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter @statecore/api dev",
    "dev:worker": "pnpm --filter @statecore/worker dev",
    "dev:telegram": "pnpm --filter @statecore/adapter-telegram dev",
    "dev:demo": "pnpm --filter @statecore/demo-web dev",
    "dev:demo-stack": "./scripts/dev-demo-stack.sh",
    "dev:cli": "STATECORE_CLI_BASE_DIR=\"$PWD\" pnpm --filter @statecore/cli dev",
    "test:core": "pnpm --filter @statecore/core test",
    "lint": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" exec tsc -p tsconfig.json --noEmit",
    "format": "node ./scripts/format/fix-format.mjs",
    "format:check": "node ./scripts/format/check-format.mjs",
    "build": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" build",
    "changeset": "pnpm dlx changeset",
    "release:status": "pnpm dlx changeset status",
    "release:verify": "node ./scripts/release/verify-release.mjs",
    "benchmark": "node ./scripts/benchmark/run-benchmark.mjs",
    "benchmark:visible": "node ./scripts/benchmark/run-visible-comparison.mjs",
    "benchmark:trend": "node ./scripts/benchmark/generate-trend-report.mjs",
    "profile:state-layer": "pnpm --filter @statecore/worker exec tsx ../../scripts/profile-state-layer.ts",
    "ci:runtime-readiness": "./scripts/ci/runtime-readiness.sh",
    "smoke:no-llm": "./scripts/smoke-no-llm.sh",
    "smoke:llm": "./scripts/smoke-llm.sh",
    "smoke:runtime": "./scripts/smoke-runtime.sh",
    "smoke:demo-web": "./scripts/smoke-demo-web.sh",
    "smoke:deploy": "./scripts/smoke-prod-compose.sh",
    "smoke:reminders": "./scripts/smoke-reminders.sh",
    "cleanup:demo-guests": "pnpm --filter @statecore/db exec tsx ../../scripts/cleanup-demo-guests.ts",
    "smoke": "pnpm smoke:no-llm && pnpm smoke:llm && pnpm smoke:runtime && pnpm smoke:reminders",
    "db:migrate": "pnpm --filter @statecore/db prisma migrate dev",
    "db:deploy": "pnpm --filter @statecore/db prisma migrate deploy",
    "db:generate": "pnpm --filter @statecore/db prisma generate",
    "db:studio": "pnpm --filter @statecore/db prisma studio",
    "seed": "pnpm --filter @statecore/db seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
