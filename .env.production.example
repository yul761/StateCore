# =========================
# Public demo
# =========================
NODE_ENV=production
CADDY_DOMAIN=demo.example.com
DEMO_RATE_LIMIT_WINDOW_MS=60000
DEMO_RATE_LIMIT_MAX=120
DEMO_TURN_RATE_LIMIT_WINDOW_MS=60000
DEMO_TURN_RATE_LIMIT_MAX=24
DEMO_GUEST_RETENTION_DAYS=7

# =========================
# Database / Redis
# =========================
POSTGRES_USER=project_memory
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=project_memory
DATABASE_URL=postgresql://project_memory:replace-me@postgres:5432/project_memory
REDIS_URL=redis://redis:6379

# =========================
# Core runtime
# =========================
PORT=3000
LOG_LEVEL=info
LOCAL_USER_TOKEN=local-dev-user

# =========================
# Feature flags
# =========================
FEATURE_LLM=true
FEATURE_TELEGRAM=false
WORKING_MEMORY_ENABLED=true
WORKING_MEMORY_USE_LLM=false
WORKING_MEMORY_MAX_RECENT_TURNS=6
WORKING_MEMORY_MAX_ITEMS_PER_FIELD=5

# =========================
# Digest behavior
# =========================
DIGEST_MAX_RECENT_EVENTS=50
DIGEST_MAX_DAYS_LOOKBACK=14
DIGEST_EVENT_BUDGET_TOTAL=40
DIGEST_EVENT_BUDGET_DOCS=10
DIGEST_EVENT_BUDGET_STREAM=30
DIGEST_NOVELTY_THRESHOLD=0.15
DIGEST_MAX_RETRIES=1
DIGEST_USE_LLM_CLASSIFIER=false
DIGEST_DEBUG=false
DIGEST_REBUILD_CHUNK_SIZE=80
DIGEST_CONCURRENCY=2
REMINDER_CONCURRENCY=1
REMINDER_BATCH_SIZE=50
REMINDER_MAX_BATCHES=4

# =========================
# Retrieval
# =========================
RETRIEVE_USE_EMBEDDINGS=false
RETRIEVE_EMBEDDING_CANDIDATE_LIMIT=24

# =========================
# Models
# =========================
MODEL_PROVIDER=openai-compatible
MODEL_API_KEY=
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-5-nano
MODEL_TIMEOUT_MS=120000

MODEL_CHAT_API_KEY=
MODEL_CHAT_BASE_URL=
MODEL_CHAT_NAME=gpt-5-nano

MODEL_RUNTIME_API_KEY=
MODEL_RUNTIME_BASE_URL=
MODEL_RUNTIME_NAME=gpt-5-nano
MODEL_RUNTIME_TIMEOUT_MS=20000
MODEL_RUNTIME_REASONING_EFFORT=low
MODEL_RUNTIME_MAX_OUTPUT_TOKENS=400

MODEL_STRUCTURED_OUTPUT_API_KEY=
MODEL_STRUCTURED_OUTPUT_BASE_URL=
MODEL_STRUCTURED_OUTPUT_NAME=gpt-5-nano
MODEL_STRUCTURED_OUTPUT_REASONING_EFFORT=low
MODEL_STRUCTURED_OUTPUT_MAX_OUTPUT_TOKENS=600

MODEL_EMBEDDING_API_KEY=
MODEL_EMBEDDING_BASE_URL=
MODEL_EMBEDDING_NAME=

# Legacy aliases still supported
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
