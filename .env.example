# =========================
# Core (required)
# =========================
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
# Optional: force the CLI to use a stable user id for automation / CI diagnostics.
STATECORE_CLI_USER_ID=
LOG_LEVEL=info

# Identity (dev-only)
LOCAL_USER_TOKEN=local-dev-user

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/statecore

# Redis
REDIS_URL=redis://localhost:6379

# =========================
# Feature flags
# =========================
FEATURE_LLM=false
FEATURE_TELEGRAM=false
WORKING_MEMORY_ENABLED=true
WORKING_MEMORY_USE_LLM=false
WORKING_MEMORY_MAX_RECENT_TURNS=6
WORKING_MEMORY_MAX_ITEMS_PER_FIELD=5

# =========================
# Digest behavior
# =========================
DIGEST_MAX_RECENT_EVENTS=50
DIGEST_MAX_DAYS_LOOKBACK=14
DIGEST_EVENT_BUDGET_TOTAL=40
DIGEST_EVENT_BUDGET_DOCS=10
DIGEST_EVENT_BUDGET_STREAM=30
DIGEST_NOVELTY_THRESHOLD=0.15
DIGEST_MAX_RETRIES=1
DIGEST_USE_LLM_CLASSIFIER=false
DIGEST_DEBUG=false
DIGEST_REBUILD_CHUNK_SIZE=80

# =========================
# Model provider (optional; required if FEATURE_LLM=true)
# =========================
RETRIEVE_USE_EMBEDDINGS=false
RETRIEVE_EMBEDDING_CANDIDATE_LIMIT=24
MODEL_PROVIDER=openai-compatible
MODEL_API_KEY=
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
MODEL_TIMEOUT_MS=120000
MODEL_CHAT_API_KEY=
MODEL_CHAT_BASE_URL=
MODEL_CHAT_NAME=
MODEL_RUNTIME_API_KEY=
MODEL_RUNTIME_BASE_URL=
MODEL_RUNTIME_NAME=
MODEL_RUNTIME_TIMEOUT_MS=
MODEL_RUNTIME_REASONING_EFFORT=low
MODEL_RUNTIME_MAX_OUTPUT_TOKENS=400
MODEL_STRUCTURED_OUTPUT_API_KEY=
MODEL_STRUCTURED_OUTPUT_BASE_URL=
MODEL_STRUCTURED_OUTPUT_NAME=
MODEL_STRUCTURED_OUTPUT_REASONING_EFFORT=
MODEL_STRUCTURED_OUTPUT_MAX_OUTPUT_TOKENS=
MODEL_EMBEDDING_API_KEY=
MODEL_EMBEDDING_BASE_URL=
MODEL_EMBEDDING_NAME=

# Legacy aliases still supported
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# =========================
# Telegram adapter (required if FEATURE_TELEGRAM=true)
# =========================
TELEGRAM_BOT_TOKEN=
PUBLIC_BASE_URL=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
ADAPTER_PORT=3001

# =========================
# Benchmark (optional)
# =========================
BENCH_PROFILE=balanced
BENCH_EVENTS=120
BENCH_INGEST_CONCURRENCY=12
BENCH_RETRIEVE_QUERIES=16
BENCH_DIGEST_RUNS=2
BENCH_TIMEOUT_MS=180000
BENCH_USER_ID=benchmark-user
BENCH_OUTPUT_DIR=benchmark-results
